{
  "database": {
    "connection_pool": {
      "min_connections": 5,
      "max_connections": 20,
      "timeout": 30
    },
    "query_timeout": 30,
    "statement_timeout": 30
  },
  "cache": {
    "redis": {
      "host": "redis",
      "port": 6379,
      "db": 0,
      "password": "",
      "max_connections": 50,
      "timeout": 5
    },
    "default_ttl": 300
  },
  "api": {
    "rate_limiting": {
      "enabled": true,
      "requests_per_minute": 60,
      "burst_limit": 10
    },
    "timeout": 30,
    "max_body_size": "10mb"
  },
  "monitoring": {
    "metrics_enabled": true,
    "tracing_enabled": true,
    "logging_level": "INFO"
  }
}